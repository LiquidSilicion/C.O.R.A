module aer_pipeline (
    input               clk,
    input               rst,
    input               rom_en,
    input               window_open,
    output [3:0]        channel_Id,
    output [31:0]       timestamp,
    output              timestamp_valid,
    output              spike_detected,
    output              window_start,
    output              fifo_full,
    output              fifo_empty,
    output              rom_done
);

    wire [23:0] rom_data, fifo_dout;
    wire        rom_valid, fifo_rd_en, raw_ts_valid;
    reg         fifo_rd_valid;
    wire [19:0] raw_ts;

    // 1-cycle read delay to match FIFO output latency
    assign fifo_rd_en = !fifo_empty;

    always @(posedge clk or posedge rst) begin
        if (rst)
            fifo_rd_valid <= 1'b0;
        else
            fifo_rd_valid <= fifo_rd_en;
    end

    // ROM Stimulus - FIXED ADDR_WIDTH
    aer_rom #(
        .MEM_FILE("aer_input.mem"),
        .MEM_DEPTH(4145),
        .ADDR_WIDTH(13)  // ✅ ceil(log2(4145)) = 13
    ) u_rom (
        .clk(clk),
        .rst(rst),
        .en(rom_en && !fifo_full),
        .aer_data(rom_data),
        .aer_valid(rom_valid),
        .rom_empty(rom_done)
    );

    // FIFO
    fifo #(
        .DATA_WIDTH(24),
        .DEPTH(64),
        .ADDR_WIDTH(6)
    ) u_fifo (
        .clk(clk),
        .rst(rst),
        .wr_en(rom_valid),
        .rd_en(fifo_rd_en),
        .din(rom_data),
        .dout(fifo_dout),
        .full(fifo_full),
        .empty(fifo_empty)
    );

    // AER Decoder
    input_from_aer u_decoder (
        .clk(clk),
        .rst(rst),
        .in(fifo_dout),
        .aer_valid(fifo_rd_valid),
        .channel_Id(channel_Id),
        .timestamp(raw_ts),
        .timestamp_valid(raw_ts_valid),
        .spike_detected(spike_detected)
    );

    // Timestamp Manager
    timestamp_manager u_ts_mgr (
        .clk(clk),
        .rst(rst),
        .timestamp(raw_ts),
        .ts_valid(raw_ts_valid),
        .window_open(window_open),
        .ts_abs(timestamp),
        .ts_abs_valid(timestamp_valid),
        .window_start(window_start),
        .window_offset()  // Unused output - OK to leave unconnected in Verilog-2001
    );

endmodule


