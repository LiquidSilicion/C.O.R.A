module tb_aer_pipeline;

    // Parameters
    parameter CLK_PERIOD = 8; // 125 MHz = 8 ns

    // Testbench signals (reg for driving, wire for monitoring)
    reg         clk;
    reg         rst;
    reg         rom_en;
    reg         window_open;
    wire [3:0]  channel_Id;
    wire [31:0] timestamp;
    wire        timestamp_valid;
    wire        spike_detected;
    wire        window_start;
    wire        fifo_full;
    wire        fifo_empty;
    wire        rom_done;

    // Monitor counter (module-level declaration)
    integer     spike_count;
    reg         monitor_en;

    // Instantiate DUT with EXPLICIT port connections (Verilog-2001)
    aer_pipeline dut (
        .clk(clk),
        .rst(rst),
        .rom_en(rom_en),
        .window_open(window_open),
        .channel_Id(channel_Id),
        .timestamp(timestamp),
        .timestamp_valid(timestamp_valid),
        .spike_detected(spike_detected),
        .window_start(window_start),
        .fifo_full(fifo_full),
        .fifo_empty(fifo_empty),
        .rom_done(rom_done)
    );

    // Clock generation
    initial begin
        clk = 1'b0;
        forever # (CLK_PERIOD/2) clk = ~clk;
    end

    // Monitor logic (separate always block - NOT nested)
    always @(posedge clk) begin
        if (monitor_en && timestamp_valid && (spike_count < 10)) begin
            $display("t=%0t | ch=%h ts=%h valid=%b spike=%b win_start=%b",
                     $time, channel_Id, timestamp, timestamp_valid, 
                     spike_detected, window_start);
            spike_count <= spike_count + 1;
        end
    end

    // Main stimulus
    initial begin
        // VCD dump
        $dumpfile("tb_aer_pipeline.vcd");
        $dumpvars(0, tb_aer_pipeline);

        // Initialize
        rst         = 1'b1;
        rom_en      = 1'b0;
        window_open = 1'b0;
        monitor_en  = 1'b0;
        spike_count = 0;

        // Release reset
        #20;
        rst = 1'b0;

        // Assert window_open for 1 cycle to latch window_start
        # (CLK_PERIOD);
        window_open = 1'b1;
        # (CLK_PERIOD);
        window_open = 1'b0;

        // Enable monitor and start ROM streaming
        monitor_en = 1'b1;
        rom_en = 1'b1;

        // Wait for ROM to finish + safety margin
        wait (rom_done);
        # (CLK_PERIOD * 20);

        // Final report
        $display("");
        $display("================================");
        $display("✅ Test complete.");
        $display("   Total spikes processed: %0d", spike_count);
        $display("   ROM empty: %b", rom_done);
        $display("================================");
        $finish;
    end

    // Optional: timeout guard to prevent infinite hang
    initial begin
        # (CLK_PERIOD * 10000); // 80 µs timeout
        $display("❌ TIMEOUT: Test exceeded maximum runtime");
        $finish;
    end

endmodule



