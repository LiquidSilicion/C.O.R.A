# W_out = np.load('W_out.npy')

# ── Convert to Q8.8 Fixed-Point ────────────────────────────────
def float_to_q8_8(float_array):
    """
    Convert float32 array to Q8.8 fixed-point (16-bit signed)
    Q8.8 range: -128.0 to +127.996 (practical: -1.0 to +1.0)
    """
    scaled = float_array * 256.0  # 2^8 fractional bits
    clipped = np.clip(scaled, -32768, 32767)  # 16-bit signed range
    return clipped.astype(np.int16)

print("🔄 Converting to Q8.8 fixed-point format...")
W_in_q8_8 = float_to_q8_8(W_in)
W_rec_q8_8 = float_to_q8_8(W_rec)
W_out_q8_8 = float_to_q8_8(W_out)

# ── Generate .coe File (Xilinx Vivado Format) ─────────────────
def generate_coe_file(weights_dict, filename):
    """Generate Xilinx .coe file for BRAM initialization"""
    with open(filename, 'w') as f:
        f.write("memory_initialization_radix=16;\n")
        f.write("memory_initialization_vector=\n")
        
        all_weights = []
        for name, weights in weights_dict.items():
            print(f"  📦 {name}: {weights.shape} → {weights.size} words")
            # Reinterpret signed int16 as unsigned uint16 for correct hex output
            all_weights.extend(weights.astype(np.uint16).flatten())
        
        total_words = len(all_weights)
        for i, val in enumerate(all_weights):
            f.write(f"{val:04X}")
            f.write("," if i < total_words - 1 else ";")
            if (i + 1) % 16 == 0:
                f.write("\n")
    print(f"✅ Generated {filename} ({total_words} words)")

# ── Generate .mem File (Icarus Verilog $readmemh Format) ──────
def generate_mem_file(weights_dict, filename):
    """Generate flat .mem file for Icarus Verilog simulation"""
    with open(filename, 'w') as f:
        for name, weights in weights_dict.items():
            # Reinterpret as uint16 to get correct two's complement hex
            for val in weights.astype(np.uint16).flatten():
                f.write(f"{val:04X}\n")
    total_lines = sum(w.size for w in weights_dict.values())
    print(f"✅ Generated {filename} ({total_lines} lines)")
# ── Create Weight Dictionary in Correct Memory Layout ─────────
print("\n📋 Organizing weights in BRAM memory layout:")
print("   Address 0x0000-0x07FF: W_in  (16×128 = 2,048 words)")
print("   Address 0x1000-0x4FFF: W_rec (128×128 = 16,384 words)")
print("   Address 0x9000-0x94FF: W_out (128×10 = 1,280 words)")

weights_for_bram = {
    'W_in': W_in_q8_8,
    'W_rec': W_rec_q8_8,
    'W_out': W_out_q8_8
}

# ── Generate Both File Formats ────────────────────────────────
print("\n🔨 Generating initialization files...")
generate_coe_file(weights_for_bram, 'weights.coe')
generate_mem_file(weights_for_bram, 'weights.mem')

# ── Verify File Contents ──────────────────────────────────────
print("\n📊 Verification:")
with open('weights.coe', 'r') as f:
    coe_lines = [l for l in f.readlines() if not l.startswith('memory')]
    coe_values = len([v for l in coe_lines for v in l.strip().replace(',', '').replace(';', '').split()])
    print(f"   weights.coe: {coe_values} hex values")

with open('weights.mem', 'r') as f:
    mem_lines = f.readlines()
    print(f"   weights.mem: {len(mem_lines)} lines")

## ── Show Sample Values ────────────────────────────────────────
print("\n📝 Sample weight values (first 8 of W_in):")
# Convert entire array to uint16 once for safe hex formatting
W_in_uint16 = W_in_q8_8.astype(np.uint16).flatten()
for i in range(8):
    float_val = W_in.flatten()[i]
    q8_8_val = W_in_q8_8.flatten()[i]
    hex_val = W_in_uint16[i]  # ← Safe uint16, no overflow
    print(f"   [{i}] Float: {float_val:+7.4f} → Q8.8: {q8_8_val:6d} → 0x{hex_val:04X}")

# ── Download Files ────────────────────────────────────────────
print("\n⬇️  Downloading files...")
files.download('weights.coe')
files.download('weights.mem')

print("\n✅ Done! Upload these files to your project:")
print("   • weights.coe → Vivado BRAM initialization")
print("   • weights.mem → Colab/Icarus simulation ($readmemh)")
