# ================================================================
# CORA SNN Accelerator - Weight Generator for BRAM Initialization
# Generates both .coe (Vivado) and .mem (Icarus/Colab) formats
# ================================================================

import numpy as np
from google.colab import files

# ── Configuration ──────────────────────────────────────────────
NI = 16    # Input channels
NH = 128   # Hidden neurons
NO = 10    # Output classes

# ── Generate Random Weights (for testing) ─────────────────────
print("🔧 Generating random weights for testing...")
np.random.seed(42)  # Reproducible

W_in = np.random.uniform(-0.5, 0.5, (NI, NH)).astype(np.float32)
W_rec = np.random.uniform(-0.5, 0.5, (NH, NH)).astype(np.float32)
W_out = np.random.uniform(-0.5, 0.5, (NH, NO)).astype(np.float32)

# ── OR Load Your Trained Weights (uncomment if you have them) ──
# W_in = np.load('W_in.npy')
